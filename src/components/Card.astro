---
export type Props = {
  to: string;
  title: string;
  gradientFrom: string;
  gradientTo: string;
};

const { to, title, gradientFrom, gradientTo } = Astro.props;
---

<a
  href={to}
  class={`card relative p-1 rounded-md transition-transform duration-200 ease-in-out hover:scale-90`}
  style={{
    backgroundImage: `linear-gradient(to right, ${gradientFrom}, ${gradientTo})`,
  }}
>
  <div
    class="card-inner bg-white dark:bg-[#18181b] p-6 rounded-md flex flex-col"
  >
    <div
      class="card-title text-gray-900 dark:text-gray-100 font-medium text-lg leading-7"
    >
      {title}
    </div>
    <hr style="border: none; border-top: 1px solid rgba(255, 255, 255, 0.1); margin: 1rem 0;">
    <div class="flex items-center justify-between mt-4">
      <div class="flex space-x-4">
        <div class="w-1/3 text-center">
          <img src="/images/bert.png" alt="BERT" class="rounded-md" />
          <p class="italic text-xs mt-2">Re-implemented BERT From Scratch</p>
        </div>
        <div class="w-1/3 text-center">
          <img src="/images/volleyball.png" alt="Volleyball" class="rounded-md" />
          <p class="italic text-xs mt-2">Referee Action Recognition</p>
        </div>
        <div class="w-1/3 text-center">
          <img src="/images/fbk_github.png" alt="fbk_github" class="rounded-md" />
          <p class="italic text-xs mt-2">Early Conformer with Zipformer-like Architecture</p>
        </div>
      </div>
    </div>
  </div>
</a>
