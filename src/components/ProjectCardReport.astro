---
const { title, description, technologies, href_github, href_report, imgSrc, imgAlt } = Astro.props;
import { Image } from 'astro:assets';
import Button from './BtnProject.astro';
import ButtonSt from './BtnProjectReport.astro';
import Technologies from './Technologies.astro';
---

<div class="flex flex-col sm:flex-row items-center mb-4 mt-3">
  <div class="flex-shrink-0 mb-4 sm:mb-0 sm:mr-8">
    <Image
      src={imgSrc}
      alt={imgAlt}
      class="w-[400px] h-[250px] object-cover rounded-md transition-transform duration-300 ease-in-out transform hover:scale-105"
      width={400}
      height={250}
    />
  </div>
  <astro-fragment class="flex-1">
    <h3
      class="text-base lg:text-xl xl:text-2xl mb-4 text-gray-800 dark:text-gray-300 text-center"
    >
      {title}
    </h3>
    <p
      class="text-xs sm:text-sm lg:text-base mb-4 text-gray-700 dark:text-gray-400 text-left px-4"
    >
      {description}
    </p>
    <Technologies technologies={technologies} />
    <div class="button-container">
      <Button text="GitHub" href={href_github} />
      <ButtonSt text="Report" href={href_report} />
    </div>
  </div>
</div>
