---
const { title, description, technologies, href, imgSrc, imgAlt } = Astro.props;
import { Image } from 'astro:assets';
import Technologies from './Technologies.astro';
---

<a href={href} target="_blank" rel="noopener noreferrer" class="block">
  <div class="flex flex-col sm:flex-row items-center gap-3 mb-2 mt-1 p-4 bg-[#F7F6F3] dark:bg-[#303030] rounded-xl shadow-sm hover:bg-gray-100 dark:hover:bg-[#444] transition-colors duration-300 cursor-pointer">
    <Image
      src={imgSrc}
      alt={imgAlt}
      class="w-[260px] h-[160px] sm:w-[280px] sm:h-[180px] object-cover rounded-md"
      width={280}
      height={180}
    />
    <div class="flex-1 max-w-[500px] px-4">
      <h3 class="text-base lg:text-lg font-semibold mb-1 text-gray-800 dark:text-gray-300 text-center sm:text-left">
        {title}
      </h3>
      <p class="text-sm text-gray-700 dark:text-gray-400 text-left mb-4">
        {description}
      </p>
      <Technologies technologies={technologies} />
    </div>
  </div>
</a>




