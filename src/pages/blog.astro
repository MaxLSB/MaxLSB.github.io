---
import Main from '../layouts/Main.astro';

// Fetch all blog posts from the `src/pages/blogs` directory
const blogs = await Astro.glob('../pages/blogs/*.md');
---



<Main title="Blog">
    <h2 class="text-5xl font-bold text-gray-900 dark:text-gray-300 mb-6">Blog</h2>
    <p class="px-4 text-gray-600 dark:text-gray-400"><i>Short articles about my interests or projects.</i></p>
    <hr style="border: none; border-top: 1px solid rgba(255, 255, 255, 0.1); margin: 1.5rem 0;">
    <p class="px-4 text-sm text-gray-500 dark:text-gray-300 mt-2"><i>Blogs incoming...</i></p>
