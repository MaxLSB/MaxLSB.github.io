---
import Main from '../layouts/Main.astro';
import Cards from '../components/Cards.astro';


---

<Main title="About Me">
  <h2 class="text-7xl font-bold text-gray-900 dark:text-gray-300 mb-8">
    About Me
  </h2>
  <div class="relative mt-8 animate-text opacity-0 translate-y-5">
  <p class="text-lg max-md:text-md mt-4">
    <i>I'm Maxence Lasbordes, a French
    <span
      class="bg-gradient-to-r from-blue-300 to-blue-500 bg-clip-text text-transparent font-bold"
      >Machine Learning Student</span
    >
    in the M2 MASH program at ENS/Paris Dauphine-PSL and third-year at T&eacutel&eacutecom SudParis, France.</i>
  </p>
</div>
<body>
  <a href="/images/CV_Maxence.pdf" class="cv-button">Paper CV (in English)</a>
</body>

<hr style="border: none; border-top: 1px solid rgba(255, 255, 255, 0.1); margin: 1rem 0;">
<h2 class="text-3xl font-bold text-gray-900 dark:text-gray-300 mt-8 mb-2">
  Experience
</h2>

<table class="table mt-8">
  <thead style="color: lightgrey; font-style: italic; font-size: 0.9em;">
    <tr>
      <th>Company</th>
      <th>Link</th>
      <th>Role</th>
      <th>Date</th>
      <th>Location</th>
    </tr>
  </thead>
<tbody>
  <tr>
    <td class="row">
        <img src="/images/FBK.jpg" alt="FBK" class="company-img">
    </td>
    <td><a href="https://www.fbk.eu/en/" target="_blank" class="company-name">Fondazione Bruno Kessler</a></td>
    <td>ML Research Intern</td>
    <td>June 2024 -<br>September 2024</td>
    <td>On-site<br> Trento, Italy</td>
</tr>
<tr>
    <td class="row">
        <img src="/images/kooping.png" alt="Kooping" class="company-img">
    </td>
    <td><a href="https://stationf.co/" class="company-name" target="_blank">Station F (Kooping)</a></td>
    <td>ML Intern</td>
    <td>June 2022 -<br>August 2022</td>
    <td>On-site<br> Paris, France</td>
  </tr>
</tbody>
</table>

<hr style="border: none; border-top: 1px solid rgba(255, 255, 255, 0.1); margin: 2rem 0;">
<h2 class="text-3xl font-bold text-gray-900 dark:text-gray-300 mt-8 mb-2">
  Academics
</h2>

<table class="table mt-8">
  <thead style="color: lightgrey; font-style: italic; font-size: 0.9em;">
    <tr>
        <th>School</th>
        <th>Link</th>
        <th>Degree</th>
        <th>Date</th>
    </tr>
  </thead>
  <tbody>
    <tr>
      <td class="row">
          <img src="/images/MASH.png" alt="MASH" class="company-img">
      </td>
      <td><a href="https://dauphine.psl.eu/formations/masters/mathematiques-et-applications/m2-mathematiques-apprentissage-sciences-humanites/programme" target="_blank" class="company-name">ENS | Paris Dauphine-PSL</a></td>
      <td>Master of Science in Machine Learning</td>
      <td>2024 - 2025</td>
  </tr>
  <tr>
      <td class="row">
          <img src="/images/TSP.png" alt="TSP" class="company-img">
      </td>
      <td><a href="https://www.telecom-sudparis.eu/" class="company-name" target="_blank">T&eacutel&eacutecom SudParis</a></td>
      <td>Master of Science in Engineering</td>
      <td>2021 - 2024</td>
    </tr>
    <tr>
      <td class="row">
          <img src="/images/FSM.png" alt="FSM" class="company-img">
      </td>
      <td><a href="https://www.fenelonsaintemarie.org/classes-preparatoires/" class="company-name" target="_blank">F&eacutenelon-Sainte-Marie</a></td>
      <td> Preparatory Classes MPSI - MP* </td>
      <td>2019 - 2021</td>
    </tr>
  </tbody>
  </table>
</Main>

<script>
  import { gsap } from 'gsap';

  document.addEventListener('astro:page-load', () => {
    gsap.to('.animate-text', {
      opacity: 1,
      y: 0,
      duration: 1,
      ease: 'power2.out',
    });
  });
</script>
