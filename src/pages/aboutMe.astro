---
import Main from '../layouts/Main.astro';


---

<Main title="About Me">
  <h2 class="text-5xl font-bold text-gray-900 dark:text-gray-300 mb-6">
    About Me
  </h2>
  <div class="relative mt-8 animate-text opacity-0 translate-y-5">
  <p class="px-4 text-gray-600 dark:text-gray-400">
    <i>I'm Maxence Lasbordes, a French
    <span 
      class="bg-gradient-to-r from-blue-300 to-blue-500 bg-clip-text text-transparent font-bold"
      >Machine Learning Student</span
    >
    in the IASD Master hosted by ENS-Ulm, Dauphine and Mines Paris with additional courses from the MVA Master at ENS Paris-Saclay. And third-year at T&eacutel&eacutecom SudParis. My areas of interest are </i>
    <span
      class="bg-gradient-to-r from-blue-300 to-blue-500 bg-clip-text text-transparent font-bold"
      >Machine Learning, Natural Language Processing (NLP) and Large Language Models (LLM).</span
    >
  </p>
</div>
<body>
  <a href="/images/CV_Maxence.pdf" class="cv-button bg-[#F7F6F3] dark:bg-[#303030] text-gray-700 dark:text-gray-200" style="margin-top: 30px;">Old Paper CV (in English)</a>
</body>
<hr style="border: none; border-top: 1px solid rgba(255, 255, 255, 0.1); margin: 1.5rem 0;">
<h2 class="text-2xl font-bold text-gray-900 dark:text-gray-300 mt-10 mb-4 px-4">
  Experience
</h2>

<div class="space-y-6 px-4">
  <!-- FBK Experience -->
  <div class="flex flex-col md:flex-row gap-4 p-4 bg-[#F7F6F3] dark:bg-[#303030] rounded-xl shadow-sm transition-all hover:shadow-md">
    <div class="w-full md:w-28 flex-shrink-0 flex items-center">
      <img src="/images/FBK.jpg" alt="FBK" class="w-16 h-16 rounded-lg object-contain">
    </div>
    <div class="flex-1">
      <div class="flex flex-col md:flex-row md:items-center gap-3 mb-1">
        <a href="https://www.fbk.eu/en/" target="_blank" class="text-lg font-semibold text-gray-700 dark:text-gray-200 hover:underline">
          Fondazione Bruno Kessler
        </a>
        <span class="text-sm bg-gray-200 dark:bg-[#2f2f2f] text-gray-800 dark:text-gray-300 px-2 py-1 rounded-full w-fit">
          Trento, Italy
        </span>
      </div>
      <p class="text-base text-gray-600 dark:text-gray-300 font-medium mb-1">
        Research Intern
      </p>
      <p class="text-sm text-gray-500 dark:text-gray-400">
        June 2024 - September 2024
      </p>
    </div>
  </div>

  <!-- Kooping Experience -->
  <div class="flex flex-col md:flex-row gap-4 p-4 bg-[#F7F6F3] dark:bg-[#303030] rounded-xl shadow-sm transition-all hover:shadow-md">
    <div class="w-full md:w-28 flex-shrink-0 flex items-center">
      <img src="/images/kooping.png" alt="Kooping" class="w-16 h-16 rounded-lg object-contain">
    </div>
    <div class="flex-1">
      <div class="flex flex-col md:flex-row md:items-center gap-3 mb-1">
        <a href="https://stationf.co/" target="_blank" class="text-lg font-semibold text-gray-700 dark:text-gray-200 hover:underline">
          Station F
        </a>
        <span class="text-sm bg-gray-100 dark:bg-[#2f2f2f] text-gray-800 dark:text-gray-300 px-2 py-1 rounded-full w-fit">
          Paris, France
        </span>
      </div>
      <p class="text-base text-gray-600 dark:text-gray-300 font-medium mb-1">
        Machine Learning Intern
      </p>
      <p class="text-sm text-gray-500 dark:text-gray-400">
        June 2022 - August 2022
      </p>
    </div>
  </div>
</div>



<!-- Academics Section -->
<h2 class="text-2xl font-bold text-gray-900 dark:text-gray-300 mt-10 mb-4 px-4">
  Academics
</h2>

<div class="grid md:grid-cols-2 gap-4 px-4">
  <!-- IASD Card -->
<div class="p-4 bg-[#F7F6F3] dark:bg-[#303030] rounded-xl shadow-sm hover:shadow-md transition-all">
  <div class="flex items-center gap-3 mb-3">
    <img src="/images/MASH.png" alt="MASH" class="w-14 h-14 rounded-lg object-contain">
    <div>
      <a href="https://dauphine.psl.eu/formations/masters/mathematiques-et-applications/m2-mathematiques-apprentissage-sciences-humanites/programme" 
         target="_blank" 
         class="text-lg font-semibold text-gray-700 dark:text-gray-200 hover:underline">
        ENS-Ulm, Paris Dauphine-PSL
      </a>
      <p class="text-sm text-gray-500 dark:text-gray-400">2024 - 2025</p>
    </div>
  </div>
  <p class="text-gray-600 dark:text-gray-300">
    IASD - MSc in Machine Learning
  </p>
</div>

  <!-- MVA Card -->
  <div class="p-4 bg-[#F7F6F3] dark:bg-[#303030] rounded-xl shadow-sm hover:shadow-md transition-all">
    <div class="flex items-center gap-3 mb-3">
      <img src="/images/MVA.png" alt="MVA" class="w-14 h-14 rounded-lg object-contain">
      <div>
        <a href="https://www.master-mva.com/" target="_blank" class="text-lg font-semibold text-gray-700 dark:text-gray-200 hover:underline">
          ENS Paris-Saclay
        </a>
        <p class="text-sm text-gray-500 dark:text-gray-400">2024 - 2025</p>
      </div>
    </div>
    <p class="text-gray-600 dark:text-gray-300">
      MVA - MSc in Machine Learning
    </p>
  </div>

  <!-- Telecom SudParis Card -->
  <div class="p-4 bg-[#F7F6F3] dark:bg-[#303030] rounded-xl shadow-sm hover:shadow-md transition-all">
    <div class="flex items-center gap-3 mb-3">
      <img src="/images/TSP.png" alt="TSP" class="w-14 h-14 rounded-lg object-contain">
      <div>
        <a href="https://www.telecom-sudparis.eu/" 
           target="_blank" 
           class="text-lg font-semibold text-gray-700 dark:text-gray-200 hover:underline">
           T&eacutel&eacutecom SudParis
        </a>
        <p class="text-sm text-gray-500 dark:text-gray-400">2021 - 2024</p>
      </div>
    </div>
    <p class="text-gray-600 dark:text-gray-300">
      Master of Science in Engineering
    </p>
  </div>

  <!-- Fénelon Card -->
  <div class="p-4 bg-[#F7F6F3] dark:bg-[#303030] rounded-xl shadow-sm hover:shadow-md transition-all">
    <div class="flex items-center gap-3 mb-3">
      <img src="/images/FSM.png" alt="FSM" class="w-14 h-14 rounded-lg object-contain">
      <div>
        <a href="https://www.fenelonsaintemarie.org/classes-preparatoires/" 
           target="_blank" 
           class="text-lg font-semibold text-gray-700 dark:text-gray-200 hover:underline">
           F&eacutenelon-Sainte-Marie
        </a>
        <p class="text-sm text-gray-500 dark:text-gray-400">2019 - 2021</p>
      </div>
    </div>
    <p class="text-gray-600 dark:text-gray-300">
      Preparatory Classes MPSI - MP*
    </p>
  </div>
</div>

</Main>

<script>
  import { gsap } from 'gsap';

  document.addEventListener('astro:page-load', () => {
    gsap.to('.animate-text', {
      opacity: 1,
      y: 0,
      duration: 1,
      ease: 'power2.out',
    });
  });
</script>
