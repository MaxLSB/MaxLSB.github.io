---
import Main from '../layouts/Main.astro';
import ProjectCard from '../components/ProjectCard.astro';
---

<Main title="Projects">
  <h2 class="text-5xl font-bold text-gray-900 dark:text-gray-300 mb-6">Projects</h2>
  <p class="px-4 mb-1 text-gray-600 dark:text-gray-400"><i>List of my projects from the most recent to the oldest.</i></p>

      

    <section class="text-left container mx-auto animate-on-load">
      <hr style="border: none; border-top: 1px solid rgba(255, 255, 255, 0.1); margin: 1.5rem 0;">
      <div class="flex flex-col animate-on-load mt-0 pt-0">

        <ProjectCard
        title="Mini-PaliGemma 2"
        description="Minimalist implementation of PaliGemma 2 and PaliGemma VLM from scratch. Weights can be loaded for inference, and detections are displayed on input images."
        technologies={['MachineLearning','NLP', 'Pytorch', 'Python']}
        href="https://github.com/MaxLSB/mini-paligemma2"
        imgSrc="/images/paligemma.png"
        imgAlt="Project"
      />
      <hr style="border: none; border-top: 1px solid rgba(255, 255, 255, 0.1); margin: 1rem 0;">

      <ProjectCard
        title="Word2Vec"
        description="Word2vec and a convolutional classifier using its embeddings to predict the sentiment of movie reviews. Implemented from scratch using Pytorch."
        technologies={['MachineLearning','NLP', 'Pytorch', 'Python']}
        href="https://github.com/MaxLSB/word2vec"
        imgSrc="/images/word2vec.png"
        imgAlt="Project"
      />
      <hr style="border: none; border-top: 1px solid rgba(255, 255, 255, 0.1); margin: 1rem 0;">

    <div class="flex flex-col animate-on-load">
      <ProjectCard
        title="Mini-Hourglass"
        description="Minimalist implementation of Hourglass, a character-level Hierarchical Transformer from scratch. Built the entire pre-training, fine-tuning and inference process for English haikus generation."
        technologies={['MachineLearning','NLP', 'Pytorch', 'Python']}
        href="https://github.com/MaxLSB/mini-hourglass"
        imgSrc="/images/hourglass.png"
        imgAlt="Project"
      />
      <hr style="border: none; border-top: 1px solid rgba(255, 255, 255, 0.1); margin: 1rem 0;">

    <div class="flex flex-col animate-on-load">
      <ProjectCard
        title="Mini-BERT \& Emotion classification"
        description="Minimalist implementation of BERT from scratch. And fine-tuned a pre-trained BERT model for emotion classification. Deployed it using Streamlit."
        technologies={['MachineLearning','NLP', 'Pytorch', 'Python']}
        href="https://github.com/MaxLSB/mini-bert"
        imgSrc="/images/bert.png"
        imgAlt="Project"
      />
      <hr style="border: none; border-top: 1px solid rgba(255, 255, 255, 0.1); margin: 1rem 0;">
      <!-- <div class="flex flex-col animate-on-load">
        <ProjectCard 
          title="Splitformer"
          description="Developed the early-zipformer and early-conformer-plus architectures for FBK's early-exit transformers models for Automatic Speech Recognition."
          technologies={['MachineLearning','ASR', 'Pytorch', 'Python']}
          href="https://github.com/augustgw/early-exit-transformer"
          imgSrc="/images/fbk_github.png"
          imgAlt="Project"
        />
      <hr style="border: none; border-top: 1px solid rgba(255, 255, 255, 0.1); margin: 1rem 0;"> -->
      <ProjectCard 
        title="Referee Action Recognition"
        description="Deployed a volleyball referee hand signal detection and classification model with Streamlit, using OpenCV, MediaPipe, Pytorch, LSTMs/CNNs and a custom made dataset."
        technologies={['ComputerVision', 'MachineLearning','OpenCV', 'Mediapipe', 'Python', 'Pytorch']}
        href="https://github.com/MaxLSB/volleyball-hand-signals-recognition"
        imgSrc="/images/volleyball.png"
        imgAlt="Project"
      />
      <hr style="border: none; border-top: 1px solid rgba(255, 255, 255, 0.1); margin: 1rem 0;">

      <ProjectCard
      title="Iterative Conditional Estimator"
      description="Implementation and application of the ICE (Iterative Conditional Estimator) algorithm to a Gaussian mixture generated by iid sources, then to Gaussians conditionally generated by a Hidden Markov Model."
      technologies={['Python']}
      href="https://github.com/MaxLSB/iterative-conditional-estimator"
      imgSrc="/images/ice.png"
      imgAlt="Project"
    />

      <hr style="border: none; border-top: 1px solid rgba(255, 255, 255, 0.1); margin: 1rem 0;">
      <ProjectCard
        title="Video Game Match Prediction"
        description="Machine Learning prediction model for forecasting the outcomes of League of Legends matches after 10 minutes of gameplay. Deployed it using Flask."
        technologies={['MachineLearning', 'Python', 'Flask', 'HTML', 'CSS', 'JavaScript']}
        href="https://github.com/MaxLSB/lol-game-prediction"
        imgSrc="/images/league.png"
        imgAlt="Project"
      />
      <hr style="border: none; border-top: 1px solid rgba(255, 255, 255, 0.1); margin: 1rem 0;">
      <ProjectCard
        title="Portfolio Website"
        description="Personal portfolio website built using an Astro template. Hosted on GitHub Pages."
        technologies={['Astro', 'HTML', 'CSS', 'JavaScript']}
        href="https://github.com/MaxLSB/MaxLSB.github.io"
        imgSrc="/images/portfolio.png"
        imgAlt="Project"
      />
      <!-- <hr style="border: none; border-top: 1px solid rgba(255, 255, 255, 0.1); margin: 1rem 0;"> -->
    </div>
  </section>
</Main>

<style>
  .floating-span {
    display: inline-block;
  }
</style>

<script>
  import { gsap } from 'gsap';

  document.addEventListener('astro:page-load', () => {
    const spans = document.querySelectorAll('.floating-span');
    spans.forEach(span => {
      gsap.to(span, {
        y: '-5',
        duration: 1,
        ease: 'power2.inOut',
        repeat: -1,
        yoyo: true,
      });
    });

    const elements = document.querySelectorAll('.animate-on-load');
    gsap.from(elements, {
      opacity: 0,
      y: 20,
      duration: 1,
      ease: 'power2.out',
      stagger: 0.3,
    });
  });
</script>
